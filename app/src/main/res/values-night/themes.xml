<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MiniZendo" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">@color/zenColor</item>
        <item name="colorPrimaryVariant">@color/zenColor</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/zenColor</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor" tools:targetApi="l">@color/zenColor</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
    </style>

    <style name="Theme.MiniZendo.NoActionBar" parent="Theme.MiniZendo">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.MiniZendo.Splash" parent="Theme.MiniZendo.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor" tools:targetApi="l">@android:color/black</item>
        <item name="android:navigationBarColor" tools:targetApi="l">@android:color/black</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>
</resources>
